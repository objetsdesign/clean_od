<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ POLICES ============ -->
    <record id="view_customization_font_list" model="ir.ui.view">
        <field name="name">customization.font.list</field>
        <field name="model">product.customization.font</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="css_family"/>
                <field name="google_font"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_customization_font" model="ir.actions.act_window">
        <field name="name">Polices</field>
        <field name="res_model">product.customization.font</field>
        <field name="view_mode">list</field>
    </record>

    <!-- ============ COULEURS ============ -->
    <record id="view_customization_color_list" model="ir.ui.view">
        <field name="name">customization.color.list</field>
        <field name="model">product.customization.color</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="html_color" widget="color"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_customization_color" model="ir.actions.act_window">
        <field name="name">Couleurs</field>
        <field name="res_model">product.customization.color</field>
        <field name="view_mode">list</field>
    </record>

    <!-- ============ CLIPARTS ============ -->
    <record id="view_customization_clipart_kanban" model="ir.ui.view">
        <field name="name">customization.clipart.kanban</field>
        <field name="model">product.customization.clipart</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="image"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click text-center">
                            <img t-att-src="kanban_image('product.customization.clipart', 'image', record.id.raw_value)"
                                 class="img img-fluid" style="max-height:80px"/>
                            <div><field name="name"/></div>
                            <div class="text-muted"><field name="category_id"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_customization_clipart_list" model="ir.ui.view">
        <field name="name">customization.clipart.list</field>
        <field name="model">product.customization.clipart</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="image" widget="image" options="{'size': [40, 40]}"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="extra_price"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_customization_clipart" model="ir.actions.act_window">
        <field name="name">Cliparts</field>
        <field name="res_model">product.customization.clipart</field>
        <field name="view_mode">kanban,list</field>
    </record>

    <record id="action_customization_clipart_category" model="ir.actions.act_window">
        <field name="name">Catégories de cliparts</field>
        <field name="res_model">product.customization.clipart.category</field>
        <field name="view_mode">list</field>
    </record>

    <!-- ============ PERSONNALISATIONS CLIENTS ============ -->
    <record id="view_product_customization_list" model="ir.ui.view">
        <field name="name">product.customization.list</field>
        <field name="model">product.customization</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="product_tmpl_id"/>
                <field name="extra_price"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="view_product_customization_form" model="ir.ui.view">
        <field name="name">product.customization.form</field>
        <field name="model">product.customization</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="product_tmpl_id"/>
                            <field name="product_id"/>
                            <field name="extra_price"/>
                        </group>
                        <group>
                            <field name="preview_image" widget="image"
                                   options="{'size': [200, 200]}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Fichier d'impression">
                            <field name="print_image" widget="image"
                                   options="{'size': [400, 400]}"/>
                        </page>
                        <page string="Récapitulatif">
                            <field name="summary" widget="text"/>
                        </page>
                        <page string="Définition technique (JSON)"
                              groups="base.group_no_one">
                            <field name="design_json" widget="text"/>
                        </page>
                        <page string="Commandes">
                            <field name="sale_line_ids">
                                <list>
                                    <field name="order_id"/>
                                    <field name="product_id"/>
                                    <field name="product_uom_qty"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_product_customization" model="ir.actions.act_window">
        <field name="name">Personnalisations clients</field>
        <field name="res_model">product.customization</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>

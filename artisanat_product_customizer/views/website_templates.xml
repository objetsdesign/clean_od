<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         Configurateur injecté dans la fiche produit eCommerce.
         On l'insère APRÈS le bloc produit principal pour obtenir une
         section pleine largeur, sans chevauchement avec le carrousel
         (dont la colonne image peut être en position sticky/absolute).
         ================================================================ -->
    <template id="product_customizer_block"
              inherit_id="website_sale.product"
              name="Configurateur de personnalisation produit">
        <xpath expr="//div[@id='product_detail_main']" position="after">
            <t t-if="product.is_customizable">
                <div id="art_customizer"
                     class="art-customizer container mt-4"
                     t-att-data-product-tmpl-id="product.id"
                     t-att-data-product-id="product.product_variant_id.id"
                     t-att-data-currency="product.currency_id.symbol">

                    <div class="art-customizer__header d-flex align-items-center
                                justify-content-between">
                        <h4 class="mb-0">
                            <i class="fa fa-paint-brush me-2"/>Personnaliser ce produit
                        </h4>
                        <button type="button"
                                class="btn btn-outline-secondary btn-sm js_art_reset">
                            <i class="fa fa-refresh me-1"/>Réinitialiser
                        </button>
                    </div>

                    <div class="art-customizer__body row g-3 mt-1">
                        <!-- Aperçu / canvas -->
                        <div class="col-lg-7">
                            <!-- Bascule 3D / 2D (visible seulement si modèle 3D).
                                 La 3D est la vue principale : on la place en
                                 premier et active par défaut. -->
                            <div class="art-viewmode btn-group mb-2 d-none"
                                 role="group">
                                <button type="button"
                                        class="btn btn-dark btn-sm js_art_view3d active">
                                    <i class="fa fa-cube me-1"/>3D
                                </button>
                                <button type="button"
                                        class="btn btn-outline-dark btn-sm
                                               js_art_view2d">
                                    <i class="fa fa-image me-1"/>2D (à plat)
                                </button>
                            </div>

                            <div class="art-stage">
                                <!-- Vue 3D (principale) -->
                                <div class="art-3d-wrap js_art_3d">
                                    <div id="art_3d_container"/>
                                    <!-- Barre rotation / taille du motif sélectionné -->
                                    <div class="art-3d-tools d-none">
                                        <div class="art-3d-tools__row">
                                            <button type="button"
                                                    class="art-3d-btn js_art_rot_l"
                                                    title="Pivoter à gauche">
                                                <i class="fa fa-undo"/>
                                            </button>
                                            <input type="range" min="0" max="359"
                                                   value="0" class="js_art_rotate"
                                                   title="Rotation"/>
                                            <button type="button"
                                                    class="art-3d-btn js_art_rot_r"
                                                    title="Pivoter à droite">
                                                <i class="fa fa-repeat"/>
                                            </button>
                                        </div>
                                        <div class="art-3d-tools__row">
                                            <button type="button"
                                                    class="art-3d-btn js_art_smaller"
                                                    title="Réduire">
                                                <i class="fa fa-search-minus"/>
                                            </button>
                                            <input type="range" min="20" max="300"
                                                   value="100" class="js_art_scale"
                                                   title="Taille"/>
                                            <button type="button"
                                                    class="art-3d-btn js_art_bigger"
                                                    title="Agrandir">
                                                <i class="fa fa-search-plus"/>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="art-3d-hint small text-muted d-none">
                                        <i class="fa fa-hand-pointer-o me-1"/>
                                        Glissez le motif pour le placer · Maj+glisser
                                        ou molette pour pivoter/redimensionner ·
                                        glissez le fond pour tourner le produit
                                    </div>
                                </div>
                                <!-- Vue 2D à plat (repli / aperçu impression) -->
                                <div class="art-canvas-wrap js_art_2d d-none">
                                    <canvas id="art_canvas"/>
                                </div>
                            </div>

                            <!-- Pastilles de coloris -->
                            <div class="art-colorways mt-2 d-none">
                                <label class="form-label small mb-1">Coloris :
                                    <span class="js_art_colorway_name fw-bold"/>
                                </label>
                                <div class="js_art_colorway_swatches d-flex
                                            flex-wrap gap-2"/>
                            </div>

                            <div class="art-areas btn-group mt-2 w-100"
                                 role="group"/>
                        </div>

                        <!-- Panneau d'outils -->
                        <div class="col-lg-5">
                            <ul class="nav nav-tabs art-tabs" role="tablist">
                                <li class="nav-item">
                                    <button class="nav-link active" data-tool="text"
                                            type="button">Texte</button>
                                </li>
                                <li class="nav-item">
                                    <button class="nav-link" data-tool="image"
                                            type="button">Image</button>
                                </li>
                                <li class="nav-item">
                                    <button class="nav-link" data-tool="clipart"
                                            type="button">Cliparts</button>
                                </li>
                            </ul>

                            <div class="art-tool-panels border border-top-0 p-3">
                                <!-- TEXTE -->
                                <div class="art-panel" data-panel="text">
                                    <input type="text" class="form-control mb-2
                                           js_art_text_input"
                                           placeholder="Saisissez votre texte"/>
                                    <label class="form-label small">Police</label>
                                    <select class="form-select mb-2 js_art_font"/>
                                    <label class="form-label small">Couleur</label>
                                    <div class="js_art_colors d-flex flex-wrap gap-1
                                                mb-2"/>
                                    <label class="form-label small">
                                        Taille : <span class="js_art_size_val">40</span>px
                                    </label>
                                    <input type="range" min="10" max="120" value="40"
                                           class="form-range mb-2 js_art_size"/>
                                    <button type="button"
                                            class="btn btn-primary w-100 js_art_add_text">
                                        <i class="fa fa-plus me-1"/>Ajouter le texte
                                    </button>
                                </div>

                                <!-- IMAGE -->
                                <div class="art-panel d-none" data-panel="image">
                                    <p class="small text-muted">
                                        Formats JPG / PNG, 5 Mo max.
                                    </p>
                                    <input type="file" accept="image/*"
                                           class="form-control js_art_image_input"/>
                                </div>

                                <!-- CLIPARTS -->
                                <div class="art-panel d-none" data-panel="clipart">
                                    <div class="js_art_clipart_grid d-flex flex-wrap
                                                gap-2"/>
                                </div>

                                <hr/>
                                <div class="d-flex justify-content-between
                                            align-items-center">
                                    <button type="button"
                                            class="btn btn-outline-danger btn-sm
                                                   js_art_delete">
                                        <i class="fa fa-trash me-1"/>Supprimer
                                        la sélection
                                    </button>
                                    <span class="art-extra-price fw-bold">
                                        Supplément :
                                        <span class="js_art_extra">0</span>
                                        <span t-esc="product.currency_id.symbol"/>
                                    </span>
                                </div>
                            </div>

                            <button type="button"
                                    class="btn btn-success w-100 mt-3 btn-lg
                                           js_art_add_cart">
                                <i class="fa fa-shopping-cart me-2"/>
                                Ajouter au panier (personnalisé)
                            </button>
                        </div>
                    </div>
                </div>
            </t>
        </xpath>
    </template>

</odoo>

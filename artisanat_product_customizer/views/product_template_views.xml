<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Onglet "Personnalisation" dans la fiche produit -->
    <record id="product_template_form_customizer" model="ir.ui.view">
        <field name="name">product.template.form.customizer</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//notebook" position="inside">
                <page name="customization" string="Personnalisation"
                      invisible="not sale_ok">
                    <group>
                        <group string="Activation">
                            <field name="is_customizable"/>
                            <field name="customization_base_price"
                                   invisible="not is_customizable"/>
                            <field name="customization_text_price"
                                   invisible="not is_customizable"/>
                            <field name="customization_image_price"
                                   invisible="not is_customizable"/>
                        </group>
                        <group string="Options proposées"
                               invisible="not is_customizable">
                            <field name="customization_font_ids"
                                   widget="many2many_tags"/>
                            <field name="customization_color_ids"
                                   widget="many2many_tags"/>
                            <field name="customization_clipart_ids"
                                   widget="many2many_tags"/>
                            <field name="customization_material_ids"
                                   widget="many2many_tags"/>
                            <field name="customization_texture_ids"
                                   widget="many2many_tags"/>
                            <field name="customization_dimension_ids"
                                   widget="many2many_tags"/>
                            <field name="allow_diy_texture"/>
                        </group>
                    </group>

                    <separator string="Zones personnalisables"
                               invisible="not is_customizable"/>
                    <field name="customization_area_ids"
                           invisible="not is_customizable">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="pos_left"/>
                            <field name="pos_top"/>
                            <field name="pos_width"/>
                            <field name="pos_height"/>
                            <field name="allow_text"/>
                            <field name="allow_image"/>
                            <field name="allow_clipart"/>
                            <field name="max_elements"/>
                            <field name="extra_price"/>
                        </list>
                    </field>

                    <separator string="Coloris du produit (changement de couleur)"
                               invisible="not is_customizable"/>
                    <div class="text-muted small mb-2"
                         invisible="not is_customizable">
                        Ajoutez une photo du produit par coloris : cliquer sur la
                        pastille échange l'image (2D) et recolore la matière (3D).
                    </div>
                    <field name="colorway_ids"
                           invisible="not is_customizable">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="image" widget="image"
                                   options="{'size': [40, 40]}"/>
                            <field name="name"/>
                            <field name="swatch_color" widget="color"/>
                            <field name="material_hex" widget="color"/>
                            <field name="extra_price"/>
                        </list>
                    </field>

                    <separator string="Vue 3D (optionnelle)"
                               invisible="not is_customizable"/>
                    <div class="alert alert-success" role="alert"
                         invisible="not is_customizable">
                        <b>Générer la 3D depuis une image</b> — Parcourez une image
                        ci-dessous puis cliquez sur <b>« Générer le .glb maintenant »</b>.
                        Le fichier <code>.glb</code> est créé <b>localement</b>,
                        sans aucun site de conversion externe.
                    </div>
                    <group invisible="not is_customizable">
                        <field name="auto_3d_from_image"/>
                    </group>
                    <group invisible="not is_customizable or not auto_3d_from_image">
                        <group>
                            <field name="model_3d_source_image" widget="image"
                                   options="{'size': [180, 180]}"/>
                        </group>
                        <group>
                            <button name="action_generate_glb_from_image"
                                    type="object"
                                    string="Générer le .glb maintenant"
                                    class="btn-primary" icon="fa-cube"/>
                            <field name="model_3d_camera_dist"/>
                        </group>
                    </group>
                    <div class="text-muted small mb-2"
                         invisible="not is_customizable or not auto_3d_from_image">
                        Parcourez votre image : le <code>.glb</code> est généré
                        (et régénéré) automatiquement à l'enregistrement, et
                        affiche directement votre image en 3D.
                    </div>

                    <separator string="Modèle 3D (.glb)"
                               invisible="not is_customizable"/>
                    <group invisible="not is_customizable">
                        <group>
                            <field name="model_3d" filename="model_3d_filename"
                                   widget="binary"/>
                            <field name="model_3d_filename" invisible="1"/>
                        </group>
                        <group>
                            <field name="model_3d_mesh"
                                   placeholder="ex: Bag_Body (laisser vide = 1er mesh)"/>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert"
                         invisible="not is_customizable or model_3d or auto_3d_from_image">
                        Importez un fichier <b>.glb</b> OU activez
                        <b>Générer la 3D depuis une image</b> pour une vue 3D
                        rotative. Sans 3D, le configurateur fonctionne en 2D.
                    </div>
                </page>
            </xpath>
        </field>
    </record>

</odoo>

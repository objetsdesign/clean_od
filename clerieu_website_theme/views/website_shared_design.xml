<odoo>

    <!--
        Design tokens partagés Clerieu (police + palette de couleurs).
        Injectés dans le <head> de website.layout afin que TOUTES les pages
        (accueil, boutique, fiche produit, story, blog...) héritent des
        mêmes variables CSS et de la même police, sans avoir à les
        redéclarer page par page.
    -->
    <template id="shared_design_tokens" name="Clerieu - Design tokens partagés" inherit_id="website.layout" active="True">
        <xpath expr="//head" position="inside">
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet"/>
        </xpath>
    </template>

</odoo>

<odoo>

    <template id="product_custom" name="Clerieu - Page produit personnalisée" inherit_id="website_sale.product">
        <xpath expr="//div[@id=&apos;wrap&apos;]" position="replace">
<div itemscope="itemscope" itemtype="http://schema.org/Product" id="wrap" class="js_sale o_wsale_product_page">

    <!-- ===== STYLES INJECTÉS ===== -->

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>

    <t t-set="editor_message">DÉPOSEZ DES BLOCS DE CONSTRUCTION ICI</t>
    <div class="oe_structure oe_empty oe_structure_not_nearest" id="oe_structure_website_sale_product_1" t-att-data-editor-message="editor_message"/>

    <div id="product_detail_gaia">
        <div style="max-width:1100px;margin:0 auto;padding:0 24px;">
            <!-- Breadcrumb -->
            <nav class="gaia-breadcrumb">
                <a t-att-href="keep(category=0, attribute_value=0, tags=0)">Tous les produits</a>
                <t t-if="category">
                    <span>›</span>
                    <a t-att-href="keep('/shop/category/%s' % slug(category), category=0)">
                        <t t-out="category.name"/>
                    </a>
                </t>
                <span>›</span>
                <strong t-field="product.name"/>
            </nav>
        </div>

        <!-- Main product grid -->
        <div class="gaia-product-grid" id="product_detail_main" data-name="Product Page" t-att-data-image_width="website.product_page_image_width" t-att-data-image_layout="website.product_page_image_layout">

            <!-- ══ LEFT : Galerie Images ══ -->
            <div class="gaia-images o_wsale_product_images" t-att-data-image-amount="len(product_variant._get_images() if product_variant else product._get_images())" t-att-data-image_width="website.product_page_image_width" t-att-data-image_layout="website.product_page_image_layout">

                <!-- Image principale -->
                <div class="gaia-main-img-wrap" id="gaiaMainWrap">
                    <t t-set="main_image_src" t-value="website.image_url(product_variant if product_variant else product, 'image_1920')"/>
                    <img id="gaiaMainImg" t-att-src="main_image_src" t-att-alt="product.name" itemprop="image" loading="eager"/>

                    <!-- Fleches navigation -->
                    <button class="gaia-arrow gaia-arrow-prev" id="gaiaArrowPrev" aria-label="Precedent">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                    </button>
                    <button class="gaia-arrow gaia-arrow-next" id="gaiaArrowNext" aria-label="Suivant">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                    </button>

                    <!-- Badge compteur -->
                    <span class="gaia-img-counter" id="gaiaCounter">1 / 1</span>
                </div>

                <!-- Miniatures -->
                <div class="gaia-thumbs" id="gaiaThumbsRow">
                    <t t-set="images" t-value="product_variant._get_images() if product_variant else product._get_images()"/>
                    <t t-foreach="images" t-as="image">
                        <div t-attf-class="gaia-thumb #{image_index == 0 and 'active' or ''}" t-att-data-index="image_index" t-att-data-src="website.image_url(image, 'image_1920')" t-att-data-thumb="website.image_url(image, 'image_256')" onclick="gaiaSelectThumb(this)">
                            <img t-att-src="website.image_url(image, 'image_256')" t-att-alt="product.name" loading="lazy"/>
                        </div>
                    </t>
                </div>

            </div>
            <!-- ══ END LEFT ══ -->

            <!-- ══ RIGHT : Details ══ -->
            <div class="gaia-details" id="product_details">
                <t t-set="base_url" t-value="website.get_base_url()"/>
                <span itemprop="url" style="display:none;" t-esc="base_url + product.website_url"/>
                <span itemprop="image" style="display:none;" t-esc="base_url + website.image_url(product, 'image_1920')"/>

                <!-- SKU + Wishlist -->
                <div class="gaia-meta-row">
                    <span class="gaia-sku">SKU : <t t-esc="product_variant.default_code or product.id"/></span>
<a href="/shop/wishlist/add" role="button" class="o_wsale_my_wish gaia-wishlist-btn js_add_to_wishlist" t-att-data-product-product-id="product_variant.id" t-att-data-product-id="product.id" title="Ajouter aux favoris">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
    </a>
</div>

                <!-- Badge Nouveau -->
                <div class="gaia-badge">Nouveau</div>
                <br/>

                <!-- Product name -->
                <h1 class="gaia-product-name" itemprop="name" t-field="product.name">Nom du produit</h1>

                <!-- Ratings -->
                <t t-if="is_view_active('website_sale.product_comment')">
                    <a href="#o_product_page_reviews" class="text-decoration-none" style="display:inline-block;margin-bottom:14px;">
                        <t t-call="portal_rating.rating_widget_stars_static">
                            <t t-set="rating_avg" t-value="product.rating_avg"/>
                            <t t-set="trans_text_plural">%s avis</t>
                            <t t-set="trans_text_singular">%s avis</t>
                            <t t-set="rating_count" t-value="(trans_text_plural if product.rating_count &gt; 1 else trans_text_singular) % product.rating_count"/>
                        </t>
                    </a>
                </t>

                <!-- Price -->
                <div class="gaia-price js_product js_main_product" style="color:#8B8B8B !important;font-size:20px;font-weight:700;">
                    <b><t t-call="website_sale.product_price"/></b>
                </div>

                <!-- Add to cart form -->
                <form t-if="product._is_add_to_cart_possible()" action="/shop/cart/update" method="POST">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()" t-nocache="csrf must be fresh"/>
                    <div class="js_product js_main_product">
                        <input type="hidden" class="product_id" name="product_id" t-att-value="product_variant.id"/>
                        <input type="hidden" class="product_template_id" name="product_template_id" t-att-value="product.id"/>
                        <input t-if="product.public_categ_ids.ids" type="hidden" class="product_category_id" name="product_category_id" t-att-value="product.public_categ_ids.ids[0]"/>

                        <!-- Variants -->
                        <t t-call="website_sale.variants">
                            <t t-set="ul_class" t-valuef="flex-column"/>
                            <t t-set="parent_combination" t-value="None"/>
                            <t t-set="combination" t-value="combination_info['combination']"/>
                        </t>

                        <p t-if="True" class="css_not_available_msg alert alert-warning" style="display:none;">Cette combinaison n'existe pas.</p>

                        <!-- CTA buttons -->
                        <t t-set="hasQuantities" t-value="false"/>
                        <t t-set="hasBuyNow" t-value="false"/>
                        <t t-set="ctaSizeBig" t-value="not hasQuantities or not hasBuyNow"/>

                        <div class="gaia-cta-group" id="o_wsale_cta_wrapper">
                            <div id="add_to_cart_wrap" t-attf-class="{{'d-none' if combination_info['prevent_zero_price_sale'] else ''}}">
                                <input type="hidden" name="add_qty" value="1"/>
                                <!-- Bouton ouvre le popup au lieu de soumettre -->
                                <button type="button" id="gaia_open_cart_popup" class="gaia-btn-primary js_check_product">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="9" cy="21" r="1"/>
                                        <circle cx="20" cy="21" r="1"/>
                                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                                    </svg>
                                    Ajouter au panier
                                </button>
                            </div>
                            <div id="product_option_block"/>
                        </div>
                    </div>
                </form>

                <!-- Contact us (when price = 0) -->
                <div id="contact_us_wrapper" t-attf-class="{{'d-flex' if combination_info['prevent_zero_price_sale'] else 'd-none'}} flex-column gap-2 mb-3">
                    <a t-att-href="website.contact_us_button_url" class="gaia-btn-outline">
                        Contactez-nous
                    </a>
                </div>

                <!-- Adviser contact button -->
                <div style="margin-bottom:20px;">
                    <a href="/contactus" class="gaia-btn-outline">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        Contacter un conseiller
                    </a>
                </div>

                <hr class="gaia-divider"/>

                <!-- Short description -->
                <div class="gaia-short-desc">
                    Livraison le jour même ou dès le lendemain offerte selon la disponibilité produit.
                </div>

                <!-- Long description -->
                <div t-field="product.description_ecommerce" class="gaia-long-desc oe_structure" placeholder="Description détaillée du produit…"/>

                <hr class="gaia-divider"/>

                <!-- Dimensions -->
                <div class="gaia-dimensions">
                    <strong>9 x 10 x 2.5 cm</strong><br/>
                    <span style="font-size:.78rem;">(Longueur x Hauteur x Largeur)</span>
                </div>

                <!-- Features -->
                <ul class="gaia-features">
                    <li>Toile</li>
                    <li>Doublure en cuir de vache</li>
                    <li>Métal doré</li>
                    <li>Fermeture à bouton-pression</li>
                    <li>Charm Circle</li>
                    <li>Une poche pour les billets</li>
                    <li>Poche à bouton-pression pour la monnaie</li>
                    <li>Trois fentes pour les cartes</li>
                </ul>

                <hr class="gaia-divider"/>

                <!-- Attributes table -->
                <t t-if="not is_view_active('website_sale_comparison.accordion_specs_item')">
                    <div id="product_attributes_simple">
                        <t t-set="single_value_attributes" t-value="product.valid_product_template_attribute_line_ids._prepare_single_value_for_display()"/>
                        <table t-attf-class="table table-sm text-muted {{'' if single_value_attributes else 'd-none'}}">
                            <t t-foreach="single_value_attributes" t-as="attribute">
                                <tr>
                                    <td>
                                        <span t-field="attribute.name"/>:
                                        <t t-foreach="single_value_attributes[attribute]" t-as="ptal">
                                            <span t-field="ptal.product_template_value_ids._only_active().name"/><t t-if="not ptal_last">, </t>
                                        </t>
                                    </td>
                                </tr>
                            </t>
                        </table>
                    </div>
                </t>

                <!-- Product documents -->
                <t t-set="product_documents" t-value="product.sudo().product_document_ids.filtered(lambda doc: doc.shown_on_product_page)"/>
                <div id="product_documents" class="my-2" t-if="product_documents">
                    <h5>Documents</h5>
                    <t t-foreach="product_documents" t-as="document_sudo">
                        <t t-set="attachment_sudo" t-value="document_sudo.ir_attachment_id"/>
                        <t t-set="target" t-value="attachment_sudo.type == 'url' and '_blank' or '_self'"/>
                        <t t-set="icon" t-value="attachment_sudo.type == 'url' and 'fa-link' or 'fa-download'"/>
                        <div>
                            <a t-att-href="'/shop/' + slug(product) + '/document/' + str(document_sudo.id)" t-att-target="target">
                                <i t-att-class="'fa ' + icon"/>
                                <t t-out="attachment_sudo.name"/>
                            </a>
                        </div>
                    </t>
                </div>

                <!-- Product accordion -->
                <t t-call="website_sale.product_accordion"/>

                <!-- Share / terms row -->
                <div id="o_product_terms_and_share" class="d-flex justify-content-between flex-column flex-md-row align-items-md-end gap-3 mt-3"/>

                <!-- Product tags -->
                <t t-if="is_view_active('website_sale.product_tags')" t-call="website_sale.product_tags">
                    <t t-set="all_product_tags" t-value="product_variant.all_product_tag_ids"/>
                </t>
            </div>
            <!-- ══ END RIGHT ══ -->

        </div>
        <!-- END grid -->

        <!-- Full website description -->
        <div itemprop="description" t-field="product.website_description" class="oe_structure oe_empty mt-5" id="product_full_description" style="max-width:1100px;margin:40px auto 0;padding:0 24px;"/>

        <div class="oe_structure oe_empty oe_structure_not_nearest mt-4" id="oe_structure_website_sale_product_2" t-att-data-editor-message="editor_message"/>

        <!-- ══════════════════════════════════════
             MODAL PANIER
        ══════════════════════════════════════ -->
        <div id="gaiaCartModal" role="dialog" aria-modal="true" aria-label="Votre panier">
            <div class="gcm-box" id="gaiaCartBox">
                <div class="gcm-header">
                    <h5>Votre panier</h5>
                    <button class="gcm-close" id="gaiaCartClose" aria-label="Fermer">✕</button>
                </div>
                <div class="gcm-body" id="gaiaCartBody">
                    <!-- Rempli dynamiquement par JS -->
                </div>
                <div class="gcm-footer">
                    <button class="gcm-btn-continue" id="gaiaCartContinue">
                        ← Continuer vos achats
                    </button>
                    <a href="/shop/cart" class="gcm-btn-checkout">
                        Passer au paiement →
                    </a>
                </div>
            </div>
        </div>

        <!-- ══ SCRIPT MODAL PANIER ══ -->
        <!-- ══ FIN MODAL PANIER ══ -->

    </div>
    <!-- END #product_detail_gaia -->

</div>
        </xpath>
    </template>

</odoo>

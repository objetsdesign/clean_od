<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shopify_sync_log_list" model="ir.ui.view">
        <field name="name">shopify.sync.log.list</field>
        <field name="model">shopify.sync.log</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'error'" decoration-success="state == 'success'">
                <field name="create_date"/>
                <field name="config_id"/>
                <field name="direction"/>
                <field name="model_name"/>
                <field name="shopify_object_type"/>
                <field name="shopify_object_id"/>
                <field name="state"/>
                <field name="message"/>
            </list>
        </field>
    </record>

    <record id="action_shopify_sync_log" model="ir.actions.act_window">
        <field name="name">Journal de synchronisation</field>
        <field name="res_model">shopify.sync.log</field>
        <field name="view_mode">list</field>
    </record>
</odoo>

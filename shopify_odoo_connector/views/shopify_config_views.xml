<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shopify_config_form" model="ir.ui.view">
        <field name="name">shopify.config.form</field>
        <field name="model">shopify.config</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_connect_private" type="object" string="Connecter"
                            class="btn-primary"
                            invisible="auth_type != 'private' or state == 'connected'"/>
                    <button name="action_connect_oauth" type="object" string="Connecter (OAuth)"
                            class="btn-primary"
                            invisible="auth_type != 'oauth' or state == 'connected'"/>
                    <button name="action_test_connection" type="object" string="Tester la connexion"
                            invisible="state != 'connected'"/>
                    <button name="action_resync_webhooks" type="object" string="Réinscrire les webhooks"
                            invisible="state != 'connected'"/>
                    <button name="action_sync_products_now" type="object" string="Importer produits"
                            invisible="state != 'connected'"/>
                    <button name="action_sync_customers_now" type="object" string="Importer clients"
                            invisible="state != 'connected'"/>
                    <button name="action_sync_orders_now" type="object" string="Importer commandes"
                            invisible="state != 'connected'"/>
                    <button name="action_sync_inventory_now" type="object" string="Importer stock"
                            invisible="state != 'connected'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,connected"/>
                </header>
                <sheet>
                    <div class="alert alert-danger" role="alert" invisible="not last_error">
                        <field name="last_error"/>
                    </div>
                    <div class="alert alert-info" role="alert" invisible="auth_type != 'private'">
                        Mode recommandé pour une seule boutique : créez une <b>app personnalisée</b>
                        dans Shopify (admin de la boutique &gt; Apps &gt; Développer des applications,
                        ou via le Dev Dashboard), activez les scopes nécessaires, puis copiez le
                        <b>token d'accès Admin API</b> ci-dessous. Aucune redirection OAuth n'est nécessaire.
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Ma boutique Shopify"/></h1>
                    </div>
                    <group>
                        <group string="Boutique">
                            <field name="shop_url" placeholder="monshop.myshopify.com"/>
                            <field name="company_id"/>
                            <field name="active"/>
                            <field name="auth_type" widget="radio"/>
                        </group>
                        <group string="Token direct (App personnalisée)" invisible="auth_type != 'private'">
                            <field name="access_token" password="True"/>
                            <field name="api_version"/>
                        </group>
                        <group string="Application OAuth publique" invisible="auth_type != 'oauth'">
                            <field name="client_id"/>
                            <field name="client_secret" password="True"/>
                            <field name="scope"/>
                            <field name="api_version"/>
                        </group>
                    </group>
                    <group string="Vérification des webhooks (optionnel mais recommandé)"
                           invisible="auth_type != 'private'">
                        <field name="client_secret" password="True"
                               help="Client Secret visible dans l'onglet 'API credentials' de votre app. Utilisé uniquement pour vérifier la signature des webhooks reçus."/>
                    </group>
                    <group>
                        <group string="Options de synchronisation">
                            <field name="sync_products"/>
                            <field name="sync_inventory"/>
                            <field name="sync_customers"/>
                            <field name="sync_orders"/>
                            <field name="sync_payments"/>
                            <field name="sync_fulfillments"/>
                        </group>
                        <group string="Paramètres par défaut">
                            <field name="default_warehouse_id"/>
                            <field name="order_team_id"/>
                            <field name="default_pricelist_id"/>
                        </group>
                    </group>
                    <group string="Suivi">
                        <field name="last_sync_products"/>
                        <field name="last_sync_orders"/>
                        <field name="last_sync_customers"/>
                    </group>
                    <notebook>
                        <page string="Emplacements Shopify">
                            <field name="location_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="shopify_location_id"/>
                                    <field name="warehouse_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Webhooks reçus">
                            <field name="webhook_log_ids" context="{'default_config_id': id}">
                                <list>
                                    <field name="create_date"/>
                                    <field name="topic"/>
                                    <field name="state"/>
                                    <field name="processing_time"/>
                                </list>
                            </field>
                        </page>
                        <page string="Journal de synchronisation">
                            <field name="sync_log_ids">
                                <list>
                                    <field name="create_date"/>
                                    <field name="direction"/>
                                    <field name="model_name"/>
                                    <field name="shopify_object_type"/>
                                    <field name="state"/>
                                    <field name="message"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_shopify_config_list" model="ir.ui.view">
        <field name="name">shopify.config.list</field>
        <field name="model">shopify.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="shop_url"/>
                <field name="state"/>
                <field name="last_sync_products"/>
                <field name="last_sync_orders"/>
            </list>
        </field>
    </record>

    <record id="action_shopify_config" model="ir.actions.act_window">
        <field name="name">Boutiques Shopify</field>
        <field name="res_model">shopify.config</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

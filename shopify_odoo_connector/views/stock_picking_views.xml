<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_shopify" model="ir.ui.view">
        <field name="name">stock.picking.form.shopify</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Shopify" invisible="not shopify_fulfillment_id">
                    <field name="shopify_fulfillment_id" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>

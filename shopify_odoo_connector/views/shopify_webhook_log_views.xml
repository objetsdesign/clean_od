<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shopify_webhook_log_list" model="ir.ui.view">
        <field name="name">shopify.webhook.log.list</field>
        <field name="model">shopify.webhook.log</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'error'" decoration-success="state == 'processed'">
                <field name="create_date"/>
                <field name="config_id"/>
                <field name="topic"/>
                <field name="shop_domain"/>
                <field name="state"/>
                <field name="processing_time"/>
            </list>
        </field>
    </record>

    <record id="view_shopify_webhook_log_form" model="ir.ui.view">
        <field name="name">shopify.webhook.log.form</field>
        <field name="model">shopify.webhook.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="config_id"/>
                        <field name="topic"/>
                        <field name="shop_domain"/>
                        <field name="state"/>
                        <field name="processing_time"/>
                    </group>
                    <group string="Erreur" invisible="not error_message">
                        <field name="error_message"/>
                    </group>
                    <group string="Payload reçu">
                        <field name="payload" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shopify_webhook_log" model="ir.actions.act_window">
        <field name="name">Journal des webhooks</field>
        <field name="res_model">shopify.webhook.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

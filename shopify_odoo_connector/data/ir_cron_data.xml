<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        La synchronisation "instantanée" se fait via les webhooks lorsque
        Odoo est accessible publiquement en HTTPS. Mais dans beaucoup de cas
        réels (serveur de test, réseau fermé, webhook manqué, panne
        temporaire, première installation...) les webhooks ne suffisent pas.

        Cette tâche planifiée est donc ACTIVE PAR DÉFAUT : c'est elle qui
        garantit que produits, clients, commandes et stock sont importés
        automatiquement même sans webhooks fonctionnels. Elle utilise un
        import incrémental (uniquement ce qui a changé depuis la dernière
        synchro) pour rester rapide, même toutes les 15 minutes.
    -->
    <record id="cron_shopify_reconciliation" model="ir.cron">
        <field name="name">Shopify : synchronisation automatique (produits, commandes, clients, stock)</field>
        <field name="model_id" ref="model_shopify_config"/>
        <field name="state">code</field>
        <field name="code">model.cron_sync_all_connected()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="email_template_edi_purchase_02" model="mail.template">
            <field name="name">Purchase: Request For Quotation Purchase</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="subject">{{ object.company_id.name }} Order (Ref {{ object.name or 'n/a' }})</field>
           <field name="email_from">
                {{ user.email_formatted or object.user_id.email_formatted or object.company_id.email_formatted }}
            </field>
            <field name="partner_to">{{ object.partner_id.id }}</field>
            <field name="description">Envoyé manuellement au fournisseur pour demander un devis</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Chér <t t-out="object.partner_id.name or ''">Brandon Freeman</t>
        <t t-if="object.partner_id.parent_id">
            (<t t-out="object.partner_id.parent_id.name or ''">Azure Interior</t>)
        </t>
        <br/><br/>
        Vous trouverez ci-joint une demande de devis <span style="font-weight:bold;" t-out="object.name or ''">P00015</span>
        <t t-if="object.partner_ref">
            avec référence : <t t-out="object.partner_ref or ''">REF_XXX</t>
        </t>
        depuis <t t-out="object.company_id.name or ''">YourCompany</t>.
        <br/><br/>
        Si vous avez des questions, n'hésitez pas à nous contacter.

        <br/><br/>
                Cordialement,

        <t t-if="not is_html_empty(object.user_id.signature)">
            <br/><br/>
            <t t-out="object.user_id.signature or ''">--<br/>Mitchell Admin</t>
        </t>
    </p>
</div></field>



        </record>

    </data>
</odoo>

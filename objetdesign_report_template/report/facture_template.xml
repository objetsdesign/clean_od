    <t t-esc="int(line.quantity) if line.quantity else '-'"/>
</td>
                
                
                
                <td style="padding:6px; text-align:center;color:#151515 !important;"><t t-esc="'{:,.2f} {}'.format(line.price_unit, o.currency_id.symbol).replace(',', ' ').replace('.', ',')"/></td>

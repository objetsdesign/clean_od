<?xml version="1.0" encoding="utf-8"?>
<odoo>

    
    <template id="print_facture_template_document">
         <t t-set="current_lang" t-value="(o.partner_id.lang or 'en_US').split('_')[0]"/>
        <main style="font-size: 18px;">
            <t t-set="company" t-value="o.company_id"/>
            <t t-set="mot_acompte" t-value="'down payment' if (o.partner_id.lang or '').startswith('en') else 'acompte'"/>
            <div class="page" style="padding: 0px; margin: 0;">
                
                <style>
                    @font-face {
                    font-family: 'NotoSerifCustom';
                    src: url('/objetdesign_report_template/static/src/font/noto-serif.regular.ttf')
                    format('truetype');
                    }
                    .quote-title {
                    font-family: 'NotoSerifCustom', serif;
                    font-size: 14px;
                    }
                    @font-face {
                    font-family: 'PlusJakartaSansLight';
                    src: url('/objetdesign_report_template/static/src/font/PlusJakartaSansLight.ttf')
                    format('truetype');
                    }
                    .quote-title_jaka {
                    font-family: 'PlusJakartaSansLight';
                    font-size: 14px;
                    }
                </style>

                
                <t t-set="titre_facture" t-value="'INVOICE' if current_lang == 'en' else 'FACTURE'"/>


<div class="row" style="margin:0;">
      <div class="quote-title" style="     background-color: rgba(128, 194, 210, 0.7);     color: white;     text-align: center;     height: 22px;     font-size: 16px;     z-index: 99999 !important;     font-weight: bold;     padding: 5px;     width: 99,7%;     display: flex;     align-items: center;     justify-content: center; ">
        <t t-esc="titre_facture"/>
    </div>
</div>

<table style="width:100%; border-collapse:collapse; color:#151515; font-family: 'Noto Serif', serif !important; background-color:#f9f9f9;">
    <tr>
        
        <td style="width:50%; vertical-align:top; padding:7px; font-size:14px;">
            <t t-if="o.move_type in ('out_invoice', 'out_refund')">
                
                <p style="margin:2px 0;">
                    <strong>
                        <t t-esc="('Contact:' if o.partner_id.lang and o.partner_id.lang.startswith('en') else 'Contact :')"/>
                    </strong>
                    <t t-esc="o.invoice_user_id.name"/>
                </p>
                <p style="margin:2px 0;">
                    <strong>
                        <t t-esc="('Email:' if o.partner_id.lang and o.partner_id.lang.startswith('en') else 'Email :')"/>
                    </strong>
                    <t t-esc="o.invoice_user_id.partner_id.email"/>
                </p>
            </t>

            <t t-elif="o.move_type in ('in_invoice', 'in_refund')">
                
                <t t-set="purchase_order" t-value="env['purchase.order'].search([('name', '=', o.invoice_origin)], limit=1)"/>
                <p style="margin:2px 0;">
                    <strong>
                        <t t-esc="('Contact:' if o.partner_id.lang and o.partner_id.lang.startswith('en') else 'Contact :')"/>
                    </strong>
                    <t t-esc="purchase_order.user_id.name if purchase_order else o.user_id.name"/>
                </p>
                <p style="margin:2px 0;">
                    <strong>
                        <t t-esc="('Email:' if o.partner_id.lang and o.partner_id.lang.startswith('en') else 'Email :')"/>
                    </strong>
                    <t t-esc="purchase_order.user_id.partner_id.email if purchase_order else o.user_id.partner_id.email"/>
                </p>
            </t>

            <t t-if="o._name == 'account.move' and o.move_type == 'out_invoice'">
                <p style="margin:2px 0;">
                    <strong>
                        <t t-esc="('Quotation N° :' if o.partner_id.lang and o.partner_id.lang.startswith('en') else 'Devis N° :')"/>
                    </strong>
                    <t t-esc="o.sale_order_id.name or ''"/>
                </p>
                <p style="margin:2px 0;">
                    <strong>
                        <t t-esc="('Order N° :' if o.partner_id.lang and o.partner_id.lang.startswith('en') else 'Commande N° :')"/>
                    </strong>
                    <t t-esc="o.sale_order_id.name or ''"/>
                </p>
            </t>

            <t t-elif="o.move_type == 'in_invoice'">
                <p style="margin:2px 0;">
                    <strong>
                        <t t-esc="('Quotation N° :' if o.partner_id.lang and o.partner_id.lang.startswith('en') else 'Devis N° :')"/>
                    </strong>
                    <t t-esc="o.invoice_origin or ''"/>
                </p>
                <p style="margin:2px 0;">
                    <strong>
                        <t t-esc="('Order N° :' if o.partner_id.lang and o.partner_id.lang.startswith('en') else 'Commande N° :')"/>
                    </strong>
                    <t t-esc="o.purchase_id.name or ''"/>
                </p>
            </t>

            <p style="margin:2px 0;">
                <strong>
                    <t t-esc="('Invoice N° :' if o.partner_id.lang and o.partner_id.lang.startswith('en') else 'Facture N° :')"/>
                </strong>
                <t t-esc="o.name or ''"/>
            </p>
            <p style="margin:2px 0;">
                <strong>
                    <t t-esc="('Customer Contact :' if o.partner_id.lang and o.partner_id.lang.startswith('en') else 'Contact Client :')"/>
                </strong>
                <t t-esc="o.partner_id.name"/>
            </p>
            <p style="margin:2px 0;">
                <strong>
                    <t t-esc="('Date :' if o.partner_id.lang and o.partner_id.lang.startswith('en') else 'Date :')"/>
                </strong>
                <t t-esc="o.invoice_date.strftime('%d/%m/%Y') if o.invoice_date else ''"/>
            </p>
        </td>

        
        <td style="width:50%; vertical-align:top; padding:7px; font-size:15px; text-align:left;">
            <p style="margin:2px 0;">
                <t t-if="o.partner_id.parent_id">
                    <t t-esc="o.partner_id.parent_id.name"/><br/>
                </t>
                <t t-esc="o.partner_id.name"/>
            </p>
            <p style="margin:2px 0;">
                <t t-esc="o.partner_id.street or ''"/>,
                <t t-esc="o.partner_id.city or ''"/>
                <t t-esc="o.partner_id.zip or ''"/>
            </p>
            <p style="margin:2px 0;">
                <t t-esc="o.partner_id.country_id.name or ''"/>
            </p>
        </td>
    </tr>
</table>
                               <t t-set="acompte" t-value="0.0"/>
                <t t-set="ht_net" t-value="(o.amount_untaxed or 0.0) - (acompte or 0.0)"/>
                <t t-set="tva_net" t-value="ht_net * 0.20"/>

                
<t t-set="current_lang" t-value="(o.partner_id.lang or 'fr_FR').split('_')[0]"/>


<table style="width:100%; font-size:14px; border:transparent !important;">
    <t t-if="not o.is_downpayment_invoice">

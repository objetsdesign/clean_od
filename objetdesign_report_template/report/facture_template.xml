            <tr style="background-color:rgba(128, 194, 210, 0.7); color:white; text-align:center; height:25px;">
    <th style="padding:3px 6px; width:20%; font-weight:700" class="quote-title">
        <b><t t-esc="('Ref.' if current_lang == 'en' else 'Réf.')"/></b>
    </th>
    <th style="padding:3px 6px; width:30%; font-weight:700" class="quote-title">
        <b><t t-esc="('Description' if current_lang == 'en' else 'Description')"/></b>
    </th>
    <th style="padding:3px 6px; width:10%; font-weight:700" class="quote-title">
        <b><t t-esc="('Qty' if current_lang == 'en' else 'Qté')"/></b>
    </th>
    <th style="padding:3px 6px; width:20%; font-weight:700" class="quote-title">
        <b><t t-esc="('Unit Price' if current_lang == 'en' else 'Prix Unitaire')"/></b>
    </th>
    <th style="padding:3px 6px; width:20%; font-weight:700" class="quote-title">
        <b><t t-esc="('Total HT' if current_lang == 'en' else 'Total HT')"/></b>
    </th>
</tr>

        </thead>
    </t>

    <tbody>
        <t t-foreach="o.invoice_line_ids" t-as="line" t-if="(line.price_subtotal or 0.0) != 0 and (line.quantity or 0.0) != 0 and 'acompte' not in (line.name or '').lower() and 'down payment' not in (line.name or '').lower()">

            <tr>
                <td style="padding:6px; vertical-align:top;color:#151515 !important;"><t t-esc="line.product_id.name"/></td>

                        <t t-if="line.product_id.x_infos"><t t-esc="line.product_id.x_infos"/></t>
                    </td>
                </tr>
            </t>
        </t>
    </tbody>
</table>

                
                                <t t-set="montant_ht_total" t-value="sum(line.price_subtotal for line in o.invoice_line_ids if 'acompte' not in (line.name or '').lower() and 'down payment' not in (line.name or '').lower())"/>

                <t t-set="acompte_total" t-value="sum(line.price_subtotal for line in o.invoice_line_ids if 'acompte' in (line.name or '').lower() or 'down payment' in (line.name or '').lower())"/>

                
                <t t-if="acompte_total != 0.0">
                    

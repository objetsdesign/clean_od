<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="delivery_template" model="ir.actions.report">
        <field name="name">OD bon de livraison</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">objetdesign_report_template.print_delivery_template</field>
        <field name="report_file">objetdesign_report_template.print_delivery_template</field>
        <field name="print_report_name">'OD bon de livraison - %s - %s' % (object.partner_id.name or '', object.name)
        </field>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
    </record>

    <template id="print_delivery_template_document">
        <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)"/>
        <main style="font-size: 18px;">
            <t t-set="company" t-value="o.company_id"/>
            <div class="page" style="padding: 0px; margin: 0;">
                <div class="row" style="margin:0;">
                    <div class="quote-title" style="
    background-color: rgba(128, 194, 210, 0.7);
    color: white;
    text-align: center;
    height: 27px;
    font-size: 16px;
    z-index: 99999 !important;
    font-weight: bold;
    padding: 2px;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
">
                        BON DE LIVRAISON N°
                        <t t-esc="o.name"/>
                    </div>
                </div>
                <table style="width:100%; border-collapse:collapse; color:#151515; font-family: 'Noto Serif', serif !important; background-color:#f9f9f9;">
                    <tr>
                        
                        <td style="width:50%; vertical-align:top; padding:7px; font-size:14px;">
                            <p style="margin: 2px 0px 0px 0%;">
                                <strong>Date de livraison Estimée :</strong>
                                <t t-esc="o.scheduled_date or ''"/>
                            </p>
                            <p style="margin: 2px 0px 0px 0%;">
                                <strong>Client :</strong>
                                <t t-esc="o.partner_id.name or ''"/>
                            </p>
                            <p style="margin: 2px 0px 0px 0%;">
                                <strong>N° Dossier :</strong>
                                <t t-esc="o.name or ''"/>
                            </p>
                            <p style="margin: 2px 0px 0px 0%;">
                                <strong>N°Commande:</strong>
                                <t t-esc="o.origin or ''"/>
                            </p>
                            <p style="margin: 2px 0px 0px 0%;">
                                <strong>Marquage Carton. Shipping mark :</strong>
                                <t t-esc="o.marquage_carton_shipping or ''"/>
                            </p>
                            <p style="margin: 2px 0px 0px 0%;">
                                <strong>Note :</strong>
                                <t t-esc="o.note"/>
                            </p>
                        </td>

                        
                        <td style="width:50%; vertical-align:top; padding:7px; font-size:15px; text-align:left;">
                            <p style="margin:2px 0 0 58%;">
                                <t t-esc="o.partner_id.name or ''"/>
                            </p>
                            <p style="margin:2px 0 0 58%;">
                                <t t-esc="o.partner_id.street or ''"/>
                            </p>
                            <p style="margin:2px 0 0 58%;">
                                <t t-esc="o.partner_id.street2 or ''"/>
                            </p>
                            <p style="margin:2px 0 0 58%;">
                                <t t-esc="o.partner_id.zip or ''"/>
                                <t t-esc="o.partner_id.city or ''"/>
                            </p>
                            <p style="margin:2px 0 0 59%;">
                                <t t-esc="o.partner_id.country_id.name or ''"/>
                            </p>
                        </td>
                    </tr>
                </table>
            </div>


            <table style="width:100%; font-size:16px; border:transparent !important;">
                <thead style="border:transparent !important;">
                    <tr style="color:white; text-align:center; height:25px; font-weight:bold; background-color: rgba(128, 194, 210, 0.7) !important;">
                        <th style="padding: 5px;">REF. Shipping mark</th>
                        <th style="padding: 5px;">DÉSIGNATION</th>
                        <th style="padding: 5px;">QTÉ</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="o.info_line_ids" t-as="line">
                        <tr>
                            <td style="padding:5px;color:#151515; text-align:left;">
                                <t t-esc="line.ref_shipping_mark or '-'"/>
                            </td>
                            <td style="padding:5px;color:#151515; text-align:left;">
                                <t t-esc="line.designation or '-'"/>
                            </td>
                            <td style="padding:5px;color:#151515; text-align:center;">
                                <t t-esc="line.qty or '-'"/>
                            </td>
                        </tr>
                    </t>
                </tbody>

            </table>

        </main>
    </template>


    <template id="print_delivery_template">
        <t t-call="web.external_layout">
            <t t-foreach="docs" t-as="o">
                <t t-call="objetdesign_report_template.print_delivery_template_document"
                   t-lang="o.partner_id.lang or 'fr_FR'"/>
            </t>
        </t>
    </template>


</odoo>
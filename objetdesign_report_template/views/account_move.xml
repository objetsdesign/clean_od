<odoo>
    <record id="view_account_form_inherit_conditionsmove" model="ir.ui.view">
        <field name="name">account.move.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
<xpath expr="//field[@name='partner_id']" position="after">
                <field name="partner_ref_related" string="Référence partenaire" readonly="1"/>
            </xpath>
<xpath expr="//field[@name='name']" position="after">
                            <field name="sale_order_ref"/>

                        </xpath>

            
            <xpath expr="//sheet//group" position="after">
                <group string="Références liées">
                    <field name="sale_order_id" readonly="1"/>
                    <field name="purchase_id" readonly="1"/>
                    <field name="is_acompte_forced_display"/>
                </group>
            </xpath>
<xpath expr="//sheet/notebook" position="inside">
    <page string="Information Report">
        <group>
            <label for="delivery" string="Delivery"/>
            <field name="delivery" nolabel="1"/>
        </group>

        <group>
            <label for="issuer" string="Issuer"/>
            <field name="issuer" nolabel="1"/>
        </group>

        <group>
            <label for="file_no" string="File N°"/>
            <field name="file_no" nolabel="1"/>
        </group>
    </page>
</xpath>

        </field>
    </record>

<record id="view_invoice_bill_tree_inherit_sale_order" model="ir.ui.view">
        <field name="name">account.move.tree.inherit.invoice.bill</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_in_invoice_bill_tree"/>
        <field name="arch" type="xml">
            
             <xpath expr="//field[@name='name']" position="before">
                           <field name="partner_ref_related" string="Reference Fournisseur"/>
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <field name="sale_order_id" string="Devis d'achat"/>
                <field name="purchase_id" string="Commande d'achat"/>
            </xpath>
        </field>
    </record>
     <record id="view_out_invoice_tree_inherit_sale_order" model="ir.ui.view">
        <field name="name">account.move.tree.inherit.sale.order</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            
            <xpath expr="//field[@name='name']" position="after">
                <field name="sale_order_id" string="Devis de Vente"/>
                <field name="sale_order_id" string="Commande de Vente"/>
            </xpath>
            <xpath expr="//field[@name='name']" position="before">
                           <field name="partner_ref_related" string="Reference Fournisseur"/>
            </xpath>
        </field>
    </record>
</odoo>
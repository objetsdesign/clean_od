<odoo>
    <record id="view_db_backup_history_tree" model="ir.ui.view">
        <field name="name">db.backup.history.tree</field>
        <field name="model">db.backup.history</field>
        <field name="arch" type="xml">
            <list string="Database Backup History">
                <field name="name"/>
                <field name="backup_date"/>
                <field name="backup_path"/> 
                <!-- <field name="file_size"/> -->
                <!-- <button name="action_download_file" icon="fa-download" type="object" class="btn-primary"/> -->
                <!-- <button name="action_delete_file" icon="fa-trash" type="object" class="btn-danger"/> -->
            </list>
        </field>
    </record>

    <record id="action_db_backup_history" model="ir.actions.act_window">
        <field name="name">Backup History</field>
        <field name="res_model">db.backup.history</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_db_backup_history" name="Backup History"
              parent="db_backup_menu_root" action="action_db_backup_history"
              sequence="1"/>
</odoo>
